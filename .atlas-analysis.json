  "keyFeatures": [
    "High throughput, low latency blockchain with instant finality",
    "Move programming language for safe smart contracts",
    "Object-centric data model with flexible ownership",
    "Parallel transaction execution",
    "Delegated Proof-of-Stake consensus",
    "Rich developer tooling (CLI, SDKs, indexers)",
    "Native support for programmable transaction blocks",
    "zkLogin for Web2 authentication",
    "Cross-chain bridge capabilities"
  ],
  "publicApiSurface": [
    "sui client - Transaction and object interaction",
    "sui move - Move package development",
    "sui keytool - Key and address management",
    "sui validator - Validator operations",
    "sui start - Local network management",
    "SuiClient (Rust SDK) - Full blockchain client",
    "ReadApi - Read blockchain data",
    "WriteApi - Submit transactions",
    "CoinReadApi - Coin and balance queries",
    "EventApi - Event subscriptions and queries",
    "GovernanceApi - Staking and governance",
    "TransactionBuilder - Construct transactions",
    "GraphQL API - Rich blockchain queries",
    "Move Framework - Standard library and sui framework"
  ]
